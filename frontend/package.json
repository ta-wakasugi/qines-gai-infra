{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "dev:all": "concurrently \"npm run dev\" \"npm run mock\"",
    "mock": "docker run --rm -p 4010:4010 -v $PWD/openapi.json:/tmp/openapi.json stoplight/prism:4 mock -h 0.0.0.0 /tmp/openapi.json",
    "mock:auto": "docker run --rm -p 4010:4010 -v $PWD/openapi.json:/tmp/openapi.json stoplight/prism:4 mock -d -h 0.0.0.0 /tmp/openapi.json",
    "lint:eslint": "eslint --ext \".js,.jsx,.ts,.tsx\" --ignore-path .gitignore .",
    "fmt": "prettier --write . && npm run lint:eslint --fix",
    "test": "jest --ci",
    "license-check": "license-checker --summary --production --excludePrivatePackages --onlyAllow \"$(tr '\\n' ';' < license-whitelist.txt | sed 's/;$//')\"",
    "prepare": "husky",
    "generate-openapi-zod-client": "openapi-zod-client ./openapi.json -o ./src/api/openapiClient.ts -a",
    "ci": "npm run generate-openapi-zod-client && npm run fmt && npm run test && npm run license-check && npm run build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^6.4.0",
    "@mui/x-data-grid": "^7.24.1",
    "@uiw/react-markdown-preview": "^5.1.3",
    "@zodios/core": "^10.9.6",
    "fs": "^0.0.1-security",
    "jotai": "^2.11.0",
    "markdown-it": "^14.1.0",
    "markdown-it-highlightjs": "^4.2.0",
    "mermaid": "^11.4.1",
    "next": "^14.2.18",
    "next-auth": "^5.0.0-beta.29",
    "openapi-zod-client": "^1.18.2",
    "puppeteer": "^24.1.0",
    "react": "^18",
    "react-dnd": "^16.0.1",
    "react-dnd-cjs": "^9.5.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dnd-html5-backend-cjs": "^9.5.1",
    "react-dom": "^18",
    "react-dropzone": "^14.3.5",
    "react-pdf": "^8.0.2",
    "react-syntax-highlighter": "^15.6.1",
    "react-virtuoso": "^4.12.3",
    "tailwindcss": "^3.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@swc/core": "^1.15.2",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.13",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.16.5",
    "@types/puppeteer": "^5.4.7",
    "@types/react": "^18",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "concurrently": "^9.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.8",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "license-checker": "^25.0.1",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5",
    "whatwg-fetch": "^3.6.20"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{jsx,js,tsx,ts}": [
      "npm run fmt"
    ]
  }
}
