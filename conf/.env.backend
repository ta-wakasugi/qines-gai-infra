# =============================================================================
# QINeS GAI Backend 環境変数設定
# =============================================================================
# このファイルをコピーして .env.backend を作成してください。
# 各環境変数の説明を参考に、適切な値を設定してください。

# =============================================================================
# LLM設定
# =============================================================================

# LLMプロバイダーの種類
# - "azure": Azure OpenAI Service を使用
# - "vllm": ローカルのvLLMサーバーを使用
LLM_TYPE="vllm"

# -----------------------------------------------------------------------------
# Azure OpenAI Service 設定 (LLM_TYPE="azure" の場合に必要)
# Azure Portal > Azure OpenAI > リソース > キーとエンドポイント から取得
# -----------------------------------------------------------------------------

# Azure OpenAI のエンドポイントURL
# 例: https://your-resource-name.openai.azure.com/
AZURE_OPENAI_ENDPOINT=""

# Azure OpenAI の APIキー
# Azure Portal の「キーとエンドポイント」から取得
AZURE_OPENAI_API_KEY=""

# Azure OpenAI の APIバージョン
# 例: 2024-02-01
# 参考: https://learn.microsoft.com/ja-jp/azure/ai-services/openai/reference
AZURE_OPENAI_API_VERSION=""

# -----------------------------------------------------------------------------
# ローカルLLM設定 (LLM_TYPE="vllm" の場合に必要)
# vLLMサーバーをローカルで起動している場合に設定
# -----------------------------------------------------------------------------

# vLLMサーバーのベースURL
# 例: http://localhost:8000/v1
OPENAI_API_BASE="http://10.22.52.200:9999/v1"

# 使用するローカルモデル名
# 例: meta-llama/Llama-2-7b-chat-hf
LOCAL_MODEL="openai/gpt-oss-120b"

# =============================================================================
# Langfuse設定 (オプション)
# LLMの監視・分析ツール。使用しない場合は USE_LANGFUSE="false" のままで可
# https://langfuse.com/ から取得
# =============================================================================

# Langfuseを使用するかどうか ("true" or "false")
USE_LANGFUSE="false"

# Langfuseの公開キー
# Langfuse Dashboard > Settings > API Keys から取得
LANGFUSE_PUBLIC_KEY="pk-lf-6fe169ea-d53b-4c7b-beba-e4c01063ea7b"

# Langfuseのシークレットキー
# Langfuse Dashboard > Settings > API Keys から取得
LANGFUSE_SECRET_KEY="sk-lf-48001ebe-6aa7-44ae-a1b1-68888f536c4e"

# LangfuseのホストURL
# セルフホストの場合: http://your-langfuse-host:3000
# クラウド版: https://cloud.langfuse.com
LANGFUSE_HOST="http://host.docker.internal:3001"

# Langfuseで使用するユーザーID (任意の識別子)
LANGFUSE_USER_ID="test"

# =============================================================================
# アプリケーション設定
# =============================================================================

# ログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL="INFO"

# アプリケーションモード
# - "local": ローカル開発モード（認証をスキップ）
# - "": 通常モード（認証必須）
APP_MODE=""

# ローカル開発時のテストユーザー情報 (APP_MODE="local" の場合に使用)
# 認証をスキップする際に使用されるユーザー情報
TEST_USER_ID="test"
TEST_USER_EMAIL="test@example.com"

# =============================================================================
# 認証設定
# =============================================================================

# 認証プロバイダー
# - "keycloak": Keycloakによる認証
# - "cognito": AWS Cognitoによる認証
AUTH_PROVIDER="keycloak"

# -----------------------------------------------------------------------------
# Keycloak設定 (AUTH_PROVIDER="keycloak" の場合に必要)
# -----------------------------------------------------------------------------

# KeycloakサーバーのURL
# 例: http://localhost:8800
KEYCLOAK_URL="http://172.29.2.232:8800"

# Keycloakのレルム名
# 例: qines-gai
KEYCLOAK_REALM="QINeS-GAI"

# =============================================================================
# AWS / S3設定
# =============================================================================

# AWSアクセスキーID
# ローカル開発時はSeaweedFSの認証情報を使用 (デフォルト: admin)
AWS_ACCESS_KEY_ID="admin"

# AWSシークレットアクセスキー
# ローカル開発時はSeaweedFSの認証情報を使用 (デフォルト: admin123)
AWS_SECRET_ACCESS_KEY="admin123"

# AWSリージョン
# 例: ap-northeast-1
AWS_DEFAULT_REGION=""

# S3バケット名
# ドキュメントファイルを保存するバケット名
# docker-compose.yml で設定される場合はここでの設定は不要
S3_BUCKET_NAME=""

# S3エンドポイントURL (オプション)
# ローカル開発時はSeaweedFSのエンドポイントを使用
# docker-compose.yml で設定される場合はここでの設定は不要
# 本番環境（AWS S3）では空欄のままにする
S3_ENDPOINT_URL=""
